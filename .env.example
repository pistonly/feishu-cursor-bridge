# === 飞书配置 ===
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_DOMAIN=feishu

# === 工作区（Cursor 项目根目录，ACP session/new 的 cwd，也是客户端读文件沙箱根）===
CURSOR_WORK_DIR=

# === @blowmage/cursor-agent-acp（子进程，标准 ACP stdio）===
# 可选：显式指定适配器入口脚本（默认使用 node_modules 内自带包）
# CURSOR_ACP_ADAPTER_ENTRY=
# 运行适配器的 Node 可执行文件（默认当前 node）
# ACP_NODE_PATH=
# 适配器内部会话文件目录（传给 --session-dir）
# CURSOR_ACP_SESSION_DIR=~/.feishu-cursor-bridge/cursor-acp-sessions
# 额外 CLI 参数（空格分隔，可用引号包裹），例如: --log-level debug
# CURSOR_ACP_EXTRA_ARGS=

# === 桥接会话映射（飞书用户 → ACP sessionId，用于进程重启后 session/load）===
# BRIDGE_SESSION_STORE=.feishu-bridge-sessions.json
# 空闲多久后视为过期并新建 ACP 会话（毫秒，默认 30 分钟）
# SESSION_IDLE_TIMEOUT_MS=1800000

# === 飞书卡片流式更新节流（毫秒）===
# FEISHU_CARD_THROTTLE_MS=800

# === 服务行为 ===
AUTO_APPROVE_PERMISSIONS=true
LOG_LEVEL=info
BRIDGE_DEBUG=false
