# === 飞书配置 ===
# 开放平台「权限管理」中需为应用开通：机器人、im:message、im:message.group_msg（群聊收消息）、
# im:message:send_as_bot、im:chat 等；缺 im:message.group_msg 时群消息不会推送到本服务。
# 默认直连；若机器只能通过代理访问飞书，可设置下方代理变量，飞书 HTTP 与 WebSocket 长连接都会尝试复用。
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_DOMAIN=feishu

# === 可选：网络代理（仅无法直连外网时设置）===
# WebSocket 专用代理，优先级最高
# wss_proxy=http://127.0.0.1:7890
# ws_proxy=http://127.0.0.1:7890
# 通用 HTTP/HTTPS 代理；未设置 ws/wss 代理时，飞书长连接也会回退使用这些变量
# https_proxy=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
# all_proxy=socks5://127.0.0.1:7890
# 检测到任一代理变量时，服务会自动为 cursor-agent-acp / cursor-agent 补上 NODE_USE_ENV_PROXY=1。
# 若你使用 systemd --user 运行服务，请确保代理变量写在该服务会读取到的 .env 里。

# === 工作区白名单（必填）===
# 逗号分隔的绝对路径：仅允许在这些根之下创建 session（/new <路径>、快捷列表项须落在某一根下）。
# 未列出的路径无法使用。每项若不存在，启动时会尝试 mkdir -p；无法创建则启动失败。
# ACP 子进程 spawn 的 cwd 取列表中第一项（与具体 session 的 cwd 无关）。
BRIDGE_WORK_ALLOWLIST=/home/you/projects,/data/repos

# /new list、/new 1 使用的快捷列表 JSON（默认 ~/.feishu-cursor-bridge/workspace-presets.json）
# BRIDGE_WORK_PRESETS_FILE=
# 若列表文件为空，启动时用以下路径初始化（逗号分隔，仅首次）
# BRIDGE_WORK_PRESETS=/path/to/repo-a,/path/to/repo-b

# === 可选：Conda PATH 注入（供 service.sh 生成 launchd/systemd PATH）===
# service.sh install / update 时会尝试把该 conda 环境的 bin 目录放到服务 PATH 最前面。
# 默认环境名为 base；若本机未检测到 Conda 根目录或对应 env 不存在，则自动跳过。
# Conda 根目录默认按顺序探测：~/miniconda3、~/anaconda3；也可显式指定 CONDA_ROOT。
# CONDA_ROOT=~/miniconda3
# CONDA_ENV_NAME=base

# 支持 `cursor-official` / `cursor-legacy` / `claude` / `codex`。
# 默认使用 Cursor 官方 ACP；Claude backend 通过 `claude-agent-acp` 接入 Claude Code；Codex backend 通过 `@zed-industries/codex-acp` 接入。
# 允许 `/new --backend <...>` 选择的后端列表；未列出的 backend 即使写在命令里也不会被启动。
ACP_BACKEND=cursor-official
ACP_ENABLED_BACKENDS=cursor-official,cursor-legacy,claude,codex
# 官方 ACP 命令路径（默认 `agent`）
# CURSOR_AGENT_PATH=agent
# 可选：显式传入官方 ACP 凭证；通常已在本机 `agent login` 时可留空
# CURSOR_API_KEY=
# CURSOR_AUTH_TOKEN=

# === cursor-agent-acp（仅 `cursor-legacy` backend 启用时使用）===
# 适配器入口固定为本仓库 cursor-agent-acp/，与桥接一致：npm start → dist；npm run dev → src + tsx（无单独环境变量）
# 启动该子进程用的 Node 可执行文件（默认当前 node）。若填了已失效的 nvm 路径会导致子进程 spawn ENOENT，可留空或删掉本行。
# CURSOR_LEGACY_NODE_PATH=
# cursor-agent-acp 内部会话目录（传给 --session-dir）
# CURSOR_LEGACY_SESSION_DIR=~/.feishu-cursor-bridge/cursor-acp-sessions
# 额外 cursor-agent-acp CLI 参数（空格分隔，可用引号包裹），例如: --log-level debug
# 默认：单次 cursor-agent 命令超时 5 分钟，失败重试 1 次（单次超时 × (retries+1) 不超过适配器 10 分钟上限）
CURSOR_LEGACY_EXTRA_ARGS="--timeout 300000 --retries 1"
# 调试 legacy 模型切换链路：打印本次 prompt 传给 cursor-agent 的完整 argv、模型参数/--resume，以及 stream-json init 事件里的模型
# ACP_TRACE_CURSOR_CLI_MODEL=true
# 调试 legacy prompt 内容：打印送进 cursor-agent 的 prompt 预览（默认最多 400 字符，注意避免在生产环境开启）
# ACP_TRACE_CURSOR_CLI_PROMPT=true


# === Claude backend 参数（仅 `claude` backend 启用时使用）===
# 默认优先使用仓库内置的 Claude ACP wrapper（dev: `src/acp/patched-claude-agent-acp.ts`；build 后: `dist/acp/patched-claude-agent-acp.js`）；
# 否则回退到 `npx -y @agentclientprotocol/claude-agent-acp`。
# CLAUDE_AGENT_ACP_COMMAND=
# CLAUDE_AGENT_ACP_EXTRA_ARGS=

# === Codex backend 参数（仅 `codex` backend 启用时使用）===
# 默认回退到 `npx -y @zed-industries/codex-acp`。
# 认证通常依赖宿主机环境变量，例如 `OPENAI_API_KEY` 或 `CODEX_API_KEY`。
# CODEX_AGENT_ACP_COMMAND=
# CODEX_AGENT_ACP_EXTRA_ARGS=

# === 单实例（同一台机器只应跑一个桥接进程，避免重复连接飞书）===
# 锁文件路径（默认 ~/.feishu-cursor-bridge/bridge.lock）；存在且 PID 仍存活时第二次启动会失败
# BRIDGE_SINGLE_INSTANCE_LOCK=~/.feishu-cursor-bridge/bridge.lock
# 设为 true 则跳过锁（仅调试；可能多实例同时连飞书）
# BRIDGE_ALLOW_MULTIPLE_INSTANCES=false

# === 桥接会话映射（飞书用户 → ACP sessionId，用于进程重启后 session/load）===
# BRIDGE_SESSION_STORE=~/.feishu-cursor-bridge/.feishu-bridge-sessions.json
# 空闲多久后视为过期并新建 ACP 会话（毫秒，默认 7 天；设为 0 或 infinity 表示永不过期）
# SESSION_IDLE_TIMEOUT_MS=604800000
# 同一飞书用户存活 session 总数上限（跨所有私聊/群/话题；默认 10；设为 0 表示不限制）
# BRIDGE_MAX_SESSIONS_PER_USER=10
# 允许执行 `/restart`、`/update` 维护命令的飞书用户 ID（逗号分隔，仅管理员私聊生效）
# BRIDGE_ADMIN_USER_IDS=ou_xxx,ou_yyy

# === 飞书卡片流式更新节流（毫秒）===
# FEISHU_CARD_THROTTLE_MS=800
# 单张卡片内容达到该长度后滚动到下一张
# FEISHU_CARD_SPLIT_MARKDOWN_THRESHOLD=3500
# 单张卡片最多聚合多少个工具条目后滚动到下一张
# FEISHU_CARD_SPLIT_TOOL_THRESHOLD=8

# 是否在飞书卡片与 /resume 回放中展示 ACP「可用命令」（Cursor 内置 slash/skills 长列表）；默认不展示
# BRIDGE_SHOW_ACP_AVAILABLE_COMMANDS=false

# === 飞书管理员升级命令（默认关闭） ===
# 开启后允许 bridge 直接识别 `/upgrade`，后台执行 `bash service.sh upgrade`。
# 默认继承 `BRIDGE_ADMIN_USER_IDS`；若显式配置任一 `BRIDGE_UPGRADE_ADMIN_*`，则仅使用升级专用 allowlist。
# 升级尝试的最近一次结果会持久化到 `BRIDGE_UPGRADE_RESULT_FILE` 指定的 JSON 文件。
# BRIDGE_ENABLE_UPGRADE_COMMAND=false
# BRIDGE_UPGRADE_ADMIN_OPEN_IDS=ou_xxx,ou_yyy
# BRIDGE_UPGRADE_ADMIN_USER_IDS=u_xxx,u_yyy
# BRIDGE_UPGRADE_ADMIN_UNION_IDS=on_xxx,on_yyy
# BRIDGE_UPGRADE_RESULT_FILE=~/.feishu-cursor-bridge/upgrade-result.json
# service.sh upgrade 默认使用当前分支；也可显式指定远端/分支。
# BRIDGE_UPGRADE_REMOTE=origin
# BRIDGE_UPGRADE_BRANCH=develop

# === 服务行为 ===
AUTO_APPROVE_PERMISSIONS=true
LOG_LEVEL=info
BRIDGE_DEBUG=false
# 按 session/slot 落盘完整 prompt/chunk/reply/error，仅调试时开启；日志目录为 `$(dirname BRIDGE_SESSION_STORE)/slot-logs`
# BRIDGE_SLOT_LOG_ENABLED=false

# === 实验参数：将 console.* 同步写入日志文件 ===
# EXPERIMENT_LOG_TO_FILE=false
# EXPERIMENT_LOG_FILE=~/.feishu-cursor-bridge/logs/bridge.log
