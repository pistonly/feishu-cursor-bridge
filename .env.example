# === 飞书配置 ===
# 飞书应用的 App ID (必填)
FEISHU_APP_ID=cli_xxxxx
# 飞书应用的 App Secret (必填)
FEISHU_APP_SECRET=xxxxx
# 飞书域名: feishu / lark / 自定义URL (默认: feishu)
FEISHU_DOMAIN=feishu

# === Cursor 配置 ===
# Cursor Agent 二进制路径 (默认: agent，使用 PATH 查找)
CURSOR_AGENT_PATH=agent
# Cursor API Key (可选, 也可通过 agent login 预认证)
CURSOR_API_KEY=
# Cursor Auth Token (可选)
CURSOR_AUTH_TOKEN=
# Cursor 工作目录 (默认: 当前目录)
CURSOR_WORK_DIR=

# === 服务配置 ===
# 自动批准所有权限请求 (默认: true)
AUTO_APPROVE_PERMISSIONS=true
# 日志级别: debug / info / warn / error (默认: info)
LOG_LEVEL=info
