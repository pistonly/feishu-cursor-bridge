{
  "name": "feishu-cursor-bridge",
  "version": "1.0.0",
  "description": "独立服务：通过飞书控制 Cursor AI Agent (基于 ACP 协议)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:adapter && npm run build:bridge",
    "build:bridge": "tsc",
    "build:adapter": "tsc -p vendor/cursor-agent-acp/tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:restart": "bash scripts/bridge-dev.sh",
    "postinstall": "npm run build:adapter"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.28.0",
    "@agentclientprotocol/sdk": "^0.16.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "commander": "^14.0.2",
    "dotenv": "^17.3.1",
    "https-proxy-agent": "^8.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "follow-redirects": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
